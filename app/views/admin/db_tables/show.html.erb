<section class="panel">
  <div class="topbar" style="margin-bottom: 16px;">
    <div>
      <h1><%= @table_name %></h1>
      <p class="muted">
        <%= @total_count %> записей
      </p>
    </div>
    <%= link_to "Все таблицы", admin_db_tables_path, class: "button secondary" %>
  </div>

  <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 16px;">
    <%= link_to "Предыдущая", admin_db_table_path(@table_name, page: [@page - 1, 1].max, per_page: @per_page), class: "button secondary", style: (@page > 1 ? "" : "pointer-events: none; opacity: 0.5;") %>
    <%= link_to "Следующая", admin_db_table_path(@table_name, page: @page + 1, per_page: @per_page), class: "button secondary", style: ((@page * @per_page) < @total_count ? "" : "pointer-events: none; opacity: 0.5;") %>
    <span class="muted">Страница <%= @page %>, по <%= @per_page %> строк</span>
  </div>

  <table>
    <thead>
      <tr>
        <% @columns.each do |column| %>
          <th><%= column.name %></th>
        <% end %>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @records.each do |record| %>
        <tr>
          <% @columns.each do |column| %>
            <td>
              <% value = record_display_value(record, column) %>
              <% if value == true %>
                Да
              <% elsif value == false %>
                Нет
              <% elsif value.is_a?(String) && value.length > 140 %>
                <pre style="white-space: pre-wrap; margin: 0;"><%= truncate(value, length: 140) %></pre>
              <% elsif value.is_a?(Hash) || value.is_a?(Array) %>
                <pre style="white-space: pre-wrap; margin: 0;"><%= JSON.pretty_generate(value) %></pre>
              <% else %>
                <%= value.nil? || value == "" ? "—" : value %>
              <% end %>
            </td>
          <% end %>
          <td><%= link_to "Изменить", edit_admin_db_table_record_path(@table_name, record), class: "button secondary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</section>
