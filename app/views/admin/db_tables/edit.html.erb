<section class="panel" style="max-width: 960px;">
  <div class="topbar" style="margin-bottom: 16px;">
    <div>
      <h1>Редактирование записи</h1>
      <p class="muted"><%= @table_name %> #<%= @record.id %></p>
    </div>
    <%= link_to "Назад к таблице", admin_db_table_path(@table_name), class: "button secondary" %>
  </div>

  <%= form_with url: admin_db_table_record_path(@table_name, @record), method: :patch do |form| %>
    <% if @record.errors.any? %>
      <div class="flash alert">
        <%= @record.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <% editable_columns.each do |column| %>
      <label style="display: block; margin-bottom: 16px;">
        <span style="display: block; font-weight: 600; margin-bottom: 6px;"><%= column.name %></span>

        <% case column_input_type(column) %>
        <% when :boolean %>
          <%= form.select column.name, [["Да", true], ["Нет", false]], selected: column_value(column.name) %>
        <% when :text %>
          <%= form.text_area column.name, value: record_display_value(@record, column), rows: 6, style: "width: 100%;" %>
        <% when :datetime_local %>
          <%= form.text_field column.name, value: record_display_value(@record, column), placeholder: "YYYY-MM-DD HH:MM:SS" %>
        <% when :date %>
          <%= form.text_field column.name, value: record_display_value(@record, column), placeholder: "YYYY-MM-DD" %>
        <% else %>
          <%= form.text_field column.name, value: record_display_value(@record, column) %>
        <% end %>
      </label>
    <% end %>

    <%= form.submit "Сохранить" %>
  <% end %>
</section>
